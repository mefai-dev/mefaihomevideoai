# ---- runtime ----
SUPERBCS_ENV=production              # production | staging | dev
SUPERBCS_DEBUG=false

# ---- database ----
# asyncpg DSN — keep the URL-encoded password out of source control
SUPERBCS_DB_DSN=postgresql+asyncpg://USER:CHANGE_ME@127.0.0.1:5432/superbcs

# ---- storage + logs ----
SUPERBCS_MEDIA_DIR=./data/media
SUPERBCS_LOG_DIR=./logs

# ---- http bind ----
SUPERBCS_BIND_HOST=127.0.0.1
SUPERBCS_BIND_PORT=8240
SUPERBCS_PUBLIC_BASE_URL=https://api.example.com

# ---- limits ----
SUPERBCS_RATE_LIMIT_PER_HOUR=30
SUPERBCS_MAX_INPUT_BYTES=8388608
SUPERBCS_JOB_TIMEOUT_SECONDS=180

# ---- worker (pull-based) ----
# 64+ character random secret shared with the GPU worker
SUPERBCS_WORKER_TOKEN=CHANGE_ME_64_HEX
# comma-separated CIDRs permitted to call /worker/* endpoints (empty = no allowlist)
SUPERBCS_WORKER_IP_ALLOWLIST=

# ---- Cloudflare Turnstile ----
SUPERBCS_TURNSTILE_SITE_KEY=CHANGE_ME_PUBLIC_KEY
SUPERBCS_TURNSTILE_SECRET=CHANGE_ME_SERVER_SECRET

# ---- request observability ----
SUPERBCS_REQUEST_ID_HEADER=X-Request-ID

# ---- cors ----
SUPERBCS_CORS_ORIGINS=https://example.com,https://www.example.com

# ---- pipeline ----
SUPERBCS_VIDEO_VARIANTS=1
SUPERBCS_QUOTA_PRIME_PER_DAY=50

# ---- signed media urls ----
# 32-byte hex (64 chars) used to sign short-lived media URLs
SUPERBCS_MEDIA_SIGNING_KEY=CHANGE_ME_64_HEX
